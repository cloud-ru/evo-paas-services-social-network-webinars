# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3007

# Database Scaling Configuration
# Most services support read/write splitting using Prisma Read Replicas extension.
# DATABASE_URL is used for WRITE operations (Primary node).
# DATABASE_REPLICA_URLS is a comma-separated list of URLs for READ operations (Replica nodes).
# If DATABASE_REPLICA_URLS is empty or not provided, the service will use DATABASE_URL for all operations.

# Auth Service
AUTH_PORT=3001
AUTH_HOST=auth
# Primary database URL for WRITE operations
AUTH_DATABASE_URL="postgresql://postgres:password@postgres:5432/social_network?schema=auth&connect_timeout=300&pgbouncer=true&connection_limit=10&pool_timeout=30"
# Comma-separated list of database URLs for READ operations. 
# Used for horizontal scaling of read traffic.
AUTH_DATABASE_REPLICA_URLS="postgresql://postgres:password@postgres:5432/social_network?schema=auth&connect_timeout=300&pgbouncer=true&connection_limit=10&pool_timeout=30"
JWT_SECRET=supersecret
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# Email Service

EMAIL_PORT=3002
EMAIL_HOST=email
EMAIL_DEV_MODE=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
SMTP_FROM="No Reply <noreply@example.com>"

# User Service
USER_PORT=3003
USER_HOST=user
# Primary database URL for WRITE operations
USER_DATABASE_URL="postgresql://postgres:password@postgres:5432/social_network?schema=user&connect_timeout=300&pgbouncer=true&connection_limit=10&pool_timeout=30"
# Comma-separated list of database URLs for READ operations.
USER_DATABASE_REPLICA_URLS="postgresql://postgres:password@postgres:5432/social_network?schema=user&connect_timeout=300&pgbouncer=true&connection_limit=10&pool_timeout=30"

# Message Service
MESSAGE_PORT=3004
MESSAGE_HOST=message
# Primary database URL for WRITE operations
MESSAGE_DATABASE_URL="postgresql://postgres:password@postgres:5432/social_network?schema=message&connect_timeout=300&pgbouncer=true&connection_limit=10&pool_timeout=30"
# Comma-separated list of database URLs for READ operations.
MESSAGE_DATABASE_REPLICA_URLS="postgresql://postgres:password@postgres:5432/social_network?schema=message&connect_timeout=300&pgbouncer=true&connection_limit=10&pool_timeout=30"

# Post Service
POST_PORT=3005
POST_HOST=post
# Primary database URL for WRITE operations
POST_DATABASE_URL="postgresql://postgres:password@postgres:5432/social_network?schema=post&connect_timeout=300&pgbouncer=true&connection_limit=10&pool_timeout=30"
# Comma-separated list of database URLs for READ operations.
POST_DATABASE_REPLICA_URLS="postgresql://postgres:password@postgres:5432/social_network?schema=post&connect_timeout=300&pgbouncer=true&connection_limit=10&pool_timeout=30"

# File Service
FILE_PORT=3006
FILE_HOST=file
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_REGION=us-east-1
S3_BUCKET=social-network
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000 
