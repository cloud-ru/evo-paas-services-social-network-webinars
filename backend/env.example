# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3007


# Auth Service
AUTH_PORT=3001
AUTH_HOST=localhost
AUTH_DATABASE_URL="postgresql://user:password@localhost:5432/social_network?schema=auth"
JWT_SECRET=supersecret
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# Email Service
EMAIL_PORT=3002
EMAIL_HOST=localhost
EMAIL_DEV_MODE=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
SMTP_FROM="No Reply <noreply@example.com>"

# User Service
USER_PORT=3003
USER_HOST=localhost
USER_DATABASE_URL="postgresql://user:password@localhost:5432/social_network?schema=user"

# Message Service
MESSAGE_PORT=3004
MESSAGE_HOST=localhost
MESSAGE_DATABASE_URL="postgresql://user:password@localhost:5432/social_network?schema=message"

# Post Service
POST_PORT=3005
POST_HOST=localhost
POST_DATABASE_URL="postgresql://user:password@localhost:5432/social_network?schema=post"

# File Service
FILE_PORT=3006
FILE_HOST=file
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_REGION=us-east-1
S3_BUCKET=social-network
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
