{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@app/types": ["libs/types/src"],
      "@app/types/*": ["libs/types/src/*"],
      "@app/prisma-auth": ["libs/prisma-auth/client"],
      "@app/prisma-user": ["libs/prisma-user/client"],
      "@app/prisma-message": ["libs/prisma-message/client"],
      "@app/prisma-post": ["libs/prisma-post/client"]
    }
  }
}
