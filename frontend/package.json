{
  "name": "social-network-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3007",
    "docker:build": "docker build -t social-network-frontend .",
    "docker:tag": "docker tag social-network-frontend:latest registry_name.cr.cloud.ru/social-network-frontend:latest",
    "docker:push": "docker push registry_name.cr.cloud.ru/social-network-frontend:latest",
    "deploy": "yarn docker:build && yarn docker:tag && yarn docker:push",
    "docker:build-base-build": "docker build -t social-network-frontend/base-build:latest -f docker/Dockerfile.base-build docker",
    "docker:tag-base-build": "docker tag social-network-frontend/base-build:latest registry_name.cr.cloud.ru/social-network-frontend/base-build:latest",
    "docker:push-base-build": "docker push registry_name.cr.cloud.ru/social-network-frontend/base-build:latest",
    "docker:deploy-base-build": "yarn docker:build-base-build && yarn docker:tag-base-build && yarn docker:push-base-build",
    "docker:build-base-run": "docker build -t social-network-frontend/base-run:latest -f docker/Dockerfile.base-run docker",
    "docker:tag-base-run": "docker tag social-network-frontend/base-run:latest registry_name.cr.cloud.ru/social-network-frontend/base-run:latest",
    "docker:push-base-run": "docker push registry_name.cr.cloud.ru/social-network-frontend/base-run:latest",
    "docker:deploy-base-run": "yarn docker:build-base-run && yarn docker:tag-base-run && yarn docker:push-base-run",
    "docker:deploy-requirements": "yarn docker:deploy-base-build && yarn docker:deploy-base-run",
    "build": "next build",
    "start": "next start -p 3007",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
